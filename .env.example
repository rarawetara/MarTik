# Скопируйте в .env из Supabase: Project Settings → API
# VITE_SUPABASE_URL = ТОЛЬКО Project URL: https://xxxx.supabase.co (одна ссылка)
# VITE_SUPABASE_ANON_KEY = ТОЛЬКО ключ: sb_publishable_... ИЛИ anon JWT (eyJ...) — не путать местами!
# НЕ подставляйте сюда строку «Connect to Postgres» (postgresql://...@db....:5432)

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx
